DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

ADMIN_USERNAME=your_admin_username
# Passwort als bcrypt-Hash (empfohlen). Erzeugen z.B. auf einem PHP-Rechner mit:
#   php -r "echo password_hash('DEIN_PASSWORT', PASSWORD_DEFAULT), PHP_EOL;"
ADMIN_PASSWORD_HASH=your_bcrypt_hash
# Alternativ (nicht empfohlen) Klartext-Fallback statt des Hashes:
# ADMIN_PASSWORD=your_admin_password

# Nur noetig, wenn api_structured_data.php genutzt wird:
PYTHON_API_KEY=your_api_key
